#include<iostream>
using namespace std;
int* calculation(int* arr,int n){
    int min;
    int temp;
    for(int i=0;i<n-1;i++){
        min=i;
        for(int j=i+1;j<n;j++){
            if(arr[min]>arr[j])
            min=j;
        }
        temp=arr[i];

        arr[i]=arr[min];
        arr[min]=temp;
        cout<<"Pass:"<<i+1<<endl;
        for(int i=0;i<n;i++){
            cout<<arr[i]<<"  ";
        }
        cout<<"\n";
    }
    return arr;
}
int main() {
    int n;
    cout<<"Enter the size:"<<endl;
    cin>>n;
    int* arr=new int[n];
    for(int i=0;i<n;i++){
        cout<<"Enter the element:"<<i<<endl;
        cin>>arr[i];
    }
    cout<<"Before Swapping:"<<endl;
    for(int i=0;i<n;i++){
        cout<<arr[i]<<"  ";
    }
    cout<<"\n";
    cout<<"Intermediate steps:"<<endl;
    arr=calculation(arr,n);
    cout<<"After Swapping:"<<endl;
    for(int i=0;i<n;i++){
        cout<<arr[i]<<"  ";
    }
}
